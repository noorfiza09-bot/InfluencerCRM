# Postgres connection string (Supabase or Neon).
# Supabase: Project Settings -> Database -> Connection string -> URI (use the "Transaction" pooler URI for serverless)
# Neon: Dashboard -> Connection Details -> Prisma / pooled connection string
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth.js / NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"

# Base URL of the deployment. Used by Auth.js for callback URLs.
# Local dev:   http://localhost:3000
# Production:  https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"
